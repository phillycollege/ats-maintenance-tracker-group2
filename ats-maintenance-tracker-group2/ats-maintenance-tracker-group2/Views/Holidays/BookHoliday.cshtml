@model ats_maintenance_tracker_group2.Models.Holiday

@{
    ViewBag.Title = "Book Holiday";
}

<h2 class="mb-4">Book a Holiday</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-group mb-3">
        <label>Start Date</label>
        @Html.TextBoxFor(model => model.StartDate, new { @class = "form-control", type = "date" })
    </div>

    <div class="form-group mb-3">
        <label>End Date</label>
        @Html.TextBoxFor(model => model.EndDate, new { @class = "form-control", type = "date" })
    </div>

    <div class="form-group mb-3">
        <label>Reason (Optional)</label>
        @Html.TextAreaFor(model => model.Reason, new { @class = "form-control", rows = 3 })
    </div>

    <button type="submit" class="btn btn-primary">
        Book Holiday
    </button>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger mt-3">
        @Html.ValidationSummary()
    </div>
}

-

@if (ViewBag.Message != null)
{
    var css = ViewBag.IsSuccess == true ? "alert-success" : "alert-danger";

    <div class="alert @css mt-3">
        @ViewBag.Message
    </div>
}