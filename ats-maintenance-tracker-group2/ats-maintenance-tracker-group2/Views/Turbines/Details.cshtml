@model ats_maintenance_tracker_group2.Models.Turbine

@{
    ViewBag.Title = "Turbine Details";
}

<br />
<div class="text-xxxs grey-5">Turbine Details</div>

<div class="box full dfb column">
    <div class="text-xl full bold-600 pd-05">@Model.WindFarm.FarmName - @Model.TurbineID</div>
    <br />

    <div class="text-xxs full bold-600 pd-05 underline"><u>Turbine Build Info</u></div>
    <div class="text-xxs full pd-05">@Model.TurbineMake</div>
    <div class="text-xxs full pd-05">@Model.TurbineModel</div>
    <br />

    <div class="text-xxs full bold-600 pd-05 underline"><u>Runtime Hours</u></div>
    <div class="text-xxs full pd-05">@Model.RuntimeHours hours</div>
    <br />
    
    <div class="text-xxs full bold-600 pd-05 underline"><u></u></div>
    <div class="text-xxs full pd-05"><b>Operational Status</b> @Model.OperationalStatus</div>
    <div class="text-xxs full pd-05">Coordinates ( @Model.Coordinates )</div>
    <div class="text-xxs full pd-05">High Winds: @Model.IsHighWinds</div>
</div>
<div class="box full dfb align-center gap-10 mt-3">
    <a href="@Url.Action("Edit", "Turbines", new { id = Model.TurbineID })">
        <button class="xxxs pd-12 pdx-2 fit whitespace-nowrap">
            <i data-lucide="square-pen" style="height: 18px;"></i> Edit
        </button>
    </a>
    <a href="@Url.Action("Index", "Turbines")">
        <button class="xxxs pd-12 pdx-2 fit outline-black whitespace-nowrap">
            Back To List
        </button>
    </a>
</div>