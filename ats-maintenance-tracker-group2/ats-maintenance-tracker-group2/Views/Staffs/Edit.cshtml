@model ats_maintenance_tracker_group2.Models.CreateStaffViewModel

@{
    ViewBag.Title = "Edit Staff";
}

<div class="text-xxl bold-600 full">
    Edit Staff
</div>

@using (Html.BeginForm()) {
    @Html.AntiForgeryToken()
    
    <div class="form-horizontal">
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        @Html.HiddenFor(model => model.Id)
        <br />

        <div class="box full pd-05">
            @Html.LabelFor(model => model.FirstName, htmlAttributes: new { @class = "text-xxs full mb-1" })
            @Html.EditorFor(model => model.FirstName, new { htmlAttributes = new { @class = "xxs pd-15 pdx-2 full mw-400", @placeholder = "First Name" } })
            @Html.ValidationMessageFor(model => model.FirstName, "", new { @class = "text-xxs full text-center error-text mb-1" })
        </div>

        <div class="box full pd-05">
            @Html.LabelFor(model => model.LastName, htmlAttributes: new { @class = "text-xxs full mb-1" })
            @Html.EditorFor(model => model.LastName, new { htmlAttributes = new { @class = "xxs pd-15 pdx-2 full mw-400", @placeholder = "Last Name" } })
            @Html.ValidationMessageFor(model => model.LastName, "", new { @class = "text-xxs full text-center error-text mb-1" })
        </div>

        <div class="box full pd-05">
            @Html.LabelFor(model => model.WorkEmailAddress, htmlAttributes: new { @class = "text-xxs full mb-1" })
            @Html.EditorFor(model => model.WorkEmailAddress, new { htmlAttributes = new { @class = "xxs pd-15 pdx-2 full mw-400", @placeholder = "Work Email Address" } })
            @Html.ValidationMessageFor(model => model.WorkEmailAddress, "", new { @class = "text-xxs full text-center error-text mb-1" })
        </div>

        <div class="box full pd-05">
            @Html.LabelFor(model => model.WorkMobileNumber, htmlAttributes: new { @class = "text-xxs full mb-1" })
            @Html.EditorFor(model => model.WorkMobileNumber, new { htmlAttributes = new { @class = "xxs pd-15 pdx-2 full mw-400", @placeholder = "Work Mobile Number" } })
            @Html.ValidationMessageFor(model => model.WorkMobileNumber, "", new { @class = "text-xxs full text-center error-text mb-1" })
        </div>

        <div class="box full pd-05">
            @Html.LabelFor(model => model.HomeMobileNumber, htmlAttributes: new { @class = "text-xxs full mb-1" })
            @Html.EditorFor(model => model.HomeMobileNumber, new { htmlAttributes = new { @class = "xxs pd-15 pdx-2 full mw-400", @placeholder = "Home Mobile Number" } })
            @Html.ValidationMessageFor(model => model.HomeMobileNumber, "", new { @class = "text-xxs full text-center error-text mb-1" })
        </div>

        <div class="box full pd-05">
            @Html.LabelFor(model => model.Address1, htmlAttributes: new { @class = "text-xxs full mb-1" })
            @Html.EditorFor(model => model.Address1, new { htmlAttributes = new { @class = "xxs pd-15 pdx-2 full mw-400", @placeholder = "Address" } })
            @Html.ValidationMessageFor(model => model.Address1, "", new { @class = "text-xxs full text-center error-text mb-1" })
        </div>

        <div class="box full pd-05">
            @Html.LabelFor(model => model.Postcode, htmlAttributes: new { @class = "text-xxs full mb-1" })
            @Html.EditorFor(model => model.Postcode, new { htmlAttributes = new { @class = "xxs pd-15 pdx-2 full mw-400", @placeholder = "Postcode" } })
            @Html.ValidationMessageFor(model => model.Postcode, "", new { @class = "text-xxs full text-center error-text mb-1" })
        </div>

        <div class="box full pd-05">
            @Html.LabelFor(model => model.City, htmlAttributes: new { @class = "text-xxs full mb-1" })
            @Html.EditorFor(model => model.City, new { htmlAttributes = new { @class = "xxs pd-15 pdx-2 full mw-400", @placeholder = "City" } })
            @Html.ValidationMessageFor(model => model.City, "", new { @class = "text-xxs full text-center error-text mb-1" })
        </div>


        <div class="box full pd-05">
            @Html.LabelFor(model => model.EmploymentRole, htmlAttributes: new { @class = "text-xxs full mb-1" })
            @Html.DropDownListFor(model => model.EmploymentRole,
                new List<SelectListItem> {
                    new SelectListItem { Text = "Engineer", Value = "Engineer" },
                    new SelectListItem { Text = "Call Handler", Value = "CallHandler" },
                    new SelectListItem { Text = "Manager", Value = "Manager" },
                },
            "Select Staff Role", htmlAttributes: new { @class = "xxs pd-15 pdx-2 full mw-400", @placeholder = "Staff Role" })
            @Html.ValidationMessageFor(model => model.EmploymentRole, "", new { @class = "text-xxs full text-center error-text mb-1" })
        </div>

        <div class="box full pd-05">
            @Html.LabelFor(model => model.Salary, htmlAttributes: new { @class = "text-xxs full mb-1" })
            @Html.TextBoxFor(model => model.Salary, new { @class = "xxs pd-15 pdx-2 full mw-400", @placeholder = "Salary", @type = "number" })
            @Html.ValidationMessageFor(model => model.Salary, "", new { @class = "text-xxs full text-center error-text mb-1" })
        </div>

        <div class="box full dfb align-center gap-10 mt-1">
            <button type="submit" class="xxxs pd-12 pdx-2 fit whitespace-nowrap">
                <i data-lucide="square-pen" style="height: 18px;"></i> Save
            </button>

            <a href="@Url.Action("Index", "Staffs")">
                <button type="button" class="xxxs pd-12 pdx-2 fit outline-black whitespace-nowrap">
                    Back To List
                </button>
            </a>
        </div>
    </div>
}