@model ats_maintenance_tracker_group2.Models.Job

@{
    ViewBag.Title = "Delete Job";
}

<div>
    <div class="box full dfb column">
        <div class="text-xxxl full bold-600 pd-05">Are you sure you want to delete this Job ?</div>
        <div class="text-xl full bold-600 pd-05">@Model.WindFarm.FarmName - @Model.TurbineID</div>
        <div class="text-xxs full pd-05 mb-05">Job Status - @Model.JobCompleteStatus</div>
        <div class="text-xs full pd-05 line-height-14" style="white-space: pre-wrap;">@Model.FaultDescription</div>
        <br />

        <div class="text-xxs full bold-600 pd-05 underline"><u>Engineer Assigned</u></div>
        <div class="text-xxs full pd-05">@Model.Staff.FirstName @Model.Staff.LastName</div>
        <br />

        <div class="text-xxs full bold-600 pd-05 underline"><u>Job Info</u></div>
        <div class="text-xxs full pd-05">GearboxServiced - @Model.GearboxServiced</div>
        <div class="text-xxs full pd-05">InternalPassengerLiftServiced - @Model.InternalPassengerLiftServiced</div>
        <div class="text-xxs full pd-05">MainGeneratorServiced - @Model.MainGeneratorServiced</div>
        <div class="text-xxs full pd-05">YawMotorServiced - @Model.YawMotorServiced</div>
        <br />

        <div class="text-xxs full bold-600 pd-05 underline"><u>Job Date and Time</u></div>
        <div class="text-xxs full pd-05">@Model.JobDate.ToString()</div>
        <br />
    </div>

    @using (Html.BeginForm()) {
        @Html.AntiForgeryToken()

        <div class="box full dfb align-center gap-10 mt-1">
            <button type="submit" class="xxxs pd-12 pdx-2 fit whitespace-nowrap delete">
                <i data-lucide="trash-2" style="height: 18px;"></i> Delete
            </button>

            <a href="@Url.Action("Index", "Jobs")">
                <button type="button" class="xxxs pd-12 pdx-2 fit outline-black whitespace-nowrap">
                    Back To List
                </button>
            </a>
        </div>
    }
</div>
